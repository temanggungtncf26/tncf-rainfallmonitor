// ─── CORS Helper ─────────────────────────────────────────────────────────────
function setCORSHeaders() {
  return ContentService.createTextOutput()
    .setMimeType(ContentService.MimeType.JSON);
}

function jsonResponse(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

// ─── doGet: health check & CORS preflight ────────────────────────────────────
function doGet(e) {
  // Kalau ada parameter action, proses sebagai GET API
  if (e && e.parameter && e.parameter.action) {
    return handleGetAction(e.parameter.action, e.parameter);
  }
  // Default: kembalikan status OK untuk health check
  return jsonResponse({ status: 'ok', message: 'TNCF Rainfall Monitor API is running' });
}

function handleGetAction(action, params) {
  if (action === 'getSiteSettings') return jsonResponse(getSiteSettings());
  if (action === 'getNormalData')   return jsonResponse(getNormalData());
  if (action === 'getRainfallData') return jsonResponse(getRainfallData(params.role, params.site));
  if (action === 'getUsersList')    return jsonResponse(getUsersList());
  return jsonResponse({ success: false, message: 'Unknown GET action: ' + action });
}

// ─── doPost: router utama untuk semua operasi CRUD ───────────────────────────
function doPost(e) {
  try {
    const payload = JSON.parse(e.postData.contents);
    const action  = payload.action;

    switch (action) {
      case 'loginUser':        return jsonResponse(loginUser(payload.data));
      case 'saveRainfallData': return jsonResponse(saveRainfallData(payload.data));
      case 'deleteData':       return jsonResponse(deleteData(payload.data.id));
      case 'getUsersList':     return jsonResponse(getUsersList());
      case 'saveUser':         return jsonResponse(saveUser(payload.data));
      case 'deleteUser':       return jsonResponse(deleteUser(payload.data.username));
      case 'getSiteSettings':  return jsonResponse(getSiteSettings());
      case 'saveSiteSetting':  return jsonResponse(saveSiteSetting(payload.data));
      case 'deleteSiteSetting':return jsonResponse(deleteSiteSetting(payload.data.site));
      case 'getNormalData':    return jsonResponse(getNormalData());
      case 'saveNormalData':   return jsonResponse(saveNormalData(payload.data));
      case 'getRainfallData':  return jsonResponse(getRainfallData(payload.data.role, payload.data.site));
      default:
        return jsonResponse({ success: false, message: 'Unknown action: ' + action });
    }
  } catch(err) {
    return jsonResponse({ success: false, message: 'Server error: ' + err.toString() });
  }
}

