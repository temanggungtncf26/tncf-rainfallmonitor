// ─── Authentication ───────────────────────────────────────────────────────────
function loginUser(formData) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  const { username, password } = formData;
  for (let i = 1; i < data.length; i++) {
    if (data[i][0].toString().toUpperCase() === username.toUpperCase().trim() &&
        data[i][1].toString() === password) {
      return { success: true, user: { username: data[i][0], nama: data[i][2], role: data[i][3], site: data[i][4] } };
    }
  }
  return { success: false, message: 'User ID atau Password salah!' };
}

// ─── Rainfall Data CRUD ───────────────────────────────────────────────────────
function saveRainfallData(payload) {
  try {
    const sheet   = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('RainfallData');
    const nilaiCH = Math.round((parseFloat(payload.ombro) / 95) * 10);
    const id      = payload.id || "CH-" + new Date().getTime();
    const rowData = [
      id,
      Utilities.formatDate(new Date(payload.tanggal), Session.getScriptTimeZone(), "yyyy-MM-dd"),
      payload.site, payload.obs, payload.ombro, nilaiCH, payload.userInput, new Date()
    ];
    if (payload.isEdit) {
      const allData  = sheet.getDataRange().getValues();
      const rowIndex = allData.findIndex(r => r[0] == payload.id);
      if (rowIndex !== -1) sheet.getRange(rowIndex + 1, 1, 1, rowData.length).setValues([rowData]);
    } else {
      sheet.appendRow(rowData);
    }
    return { success: true };
  } catch(e) { return { success: false, message: e.toString() }; }
}

function getRainfallData(role, userSite) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('RainfallData');
    if (!sheet) return { success: true, data: [] };
    const rawData = sheet.getDataRange().getValues();
    const headers = rawData.shift();
    let filtered  = rawData;
    if (role === 'STAFF') filtered = rawData.filter(row => row[2] === userSite);
    const cleanData = filtered.map(row => {
      let obj = {};
      headers.forEach((header, i) => {
        let val = row[i];
        if (val instanceof Date) val = Utilities.formatDate(val, Session.getScriptTimeZone(), "yyyy-MM-dd");
        obj[header.replace(/\s/g, '_')] = (val === null || val === undefined) ? "" : val;
      });
      return obj;
    }).reverse();
    return { success: true, data: cleanData };
  } catch(e) { return { success: false, message: e.toString() }; }
}

function deleteData(id) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('RainfallData');
    const data  = sheet.getDataRange().getValues();
    const idx   = data.findIndex(r => r[0] == id);
    if (idx !== -1) { sheet.deleteRow(idx + 1); return { success: true }; }
    return { success: false, message: "ID tidak ditemukan" };
  } catch(e) { return { success: false, message: e.toString() }; }
}

// ─── Users ────────────────────────────────────────────────────────────────────
function getUsersList() {
  const data = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users').getDataRange().getValues();
  data.shift();
  return { success: true, data: data.map(r => ({ username:r[0], password:r[1], nama:r[2], role:r[3], site:r[4] })) };
}
function saveUser(p) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  if (p.isEdit) {
    const idx = data.findIndex(r => r[0] == p.oldUsername);
    if (idx !== -1) sheet.getRange(idx+1,1,1,5).setValues([[p.username.toUpperCase(),p.password,p.nama,p.role,p.site]]);
  } else {
    sheet.appendRow([p.username.toUpperCase(),p.password,p.nama,p.role,p.site]);
  }
  return { success: true };
}
function deleteUser(u) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
  const data  = sheet.getDataRange().getValues();
  const idx   = data.findIndex(r => r[0] == u);
  if (idx !== -1) sheet.deleteRow(idx+1);
  return { success: true };
}

// ─── Site Settings ────────────────────────────────────────────────────────────
function getSiteSettings() {
  const data = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Settings').getDataRange().getValues();
  data.shift();
  let m = {};
  data.forEach(r => { m[r[0]] = r[1].toString().split(',').map(s => s.trim()); });
  return { success: true, data: m };
}
function saveSiteSetting(p) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Settings');
  const data  = sheet.getDataRange().getValues();
  const idx   = data.findIndex(r => r[0] == p.oldSiteName);
  if (idx !== -1) sheet.getRange(idx+1,1,1,2).setValues([[p.site,p.obs]]);
  else sheet.appendRow([p.site,p.obs]);
  return { success: true };
}
function deleteSiteSetting(s) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Settings');
  const data  = sheet.getDataRange().getValues();
  const idx   = data.findIndex(r => r[0] == s);
  if (idx !== -1) sheet.deleteRow(idx+1);
  return { success: true };
}

// ─── Normal Data ──────────────────────────────────────────────────────────────
function getNormalData() {
  const data = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('NormalData').getDataRange().getValues();
  data.shift();
  let m = {};
  data.forEach(r => { m[r[0]] = r.slice(1,13); });
  return { success: true, data: m };
}
function saveNormalData(p) {
  const sheet   = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('NormalData');
  const data    = sheet.getDataRange().getValues();
  const idx     = data.findIndex(r => r[0] == p.site);
  const rowData = [p.site, ...p.values];
  if (idx !== -1) sheet.getRange(idx+1,1,1,13).setValues([rowData]);
  else sheet.appendRow(rowData);
  return { success: true, message: 'Simpan berhasil' };
}
